{
  "name": "aml-checker-root",
  "version": "1.0.0",
  "scripts": {
    "test": "npm run test:auth && npm run test:core && npm run test:adapter && npm run test:gateway && npm run test:frontend",
    "test:auth": "cd auth-service && npm test",
    "test:core": "cd core-service && npm test",
    "test:adapter": "cd op-adapter && npm test",
    "test:gateway": "cd api-gateway && npm test",
    "test:frontend": "cd frontend && npm test",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:headed": "npx playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "npx playwright test --config=tests/e2e/playwright.config.ts --debug",
    "test:e2e:report": "npx playwright show-report playwright-report"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "dotenv": "^16.4.5",
    "mongodb": "^6.6.0",
    "typescript": "^5.4.5"
  }
}
