# E2E Test Environment — copy to .env.test and fill in values
# NEVER commit .env.test to version control

# Frontend URL (nginx, port 80)
E2E_BASE_URL=http://localhost

# API Gateway URL (direct, for API calls in setup and tests)
E2E_GATEWAY_URL=http://localhost:8080

# Pre-seeded SuperAdmin credentials (from README seed step)
E2E_SUPERADMIN_EMAIL=super@admin.com
E2E_SUPERADMIN_PASSWORD=superadmin

# MongoDB URI — currently NOT used by test code (reset-password E2E skipped, Option B).
# Uncomment and fill in if mongoHelper.ts is added in the future.
# E2E_MONGO_URI=mongodb://admin:<password>@localhost:27017/auth_db?authSource=admin
